{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-techniques.dev/schemas/technique.schema.json",
  "title": "Technique Frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "domain",
    "status",
    "origin",
    "owners",
    "tags",
    "summary",
    "maturity_score",
    "rigor_level",
    "reversibility",
    "review_required",
    "validation_strength",
    "public_safety_reviewed_at",
    "export_ready",
    "relations",
    "evidence"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^AOA-T-[0-9]{4}$"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "domain": {
      "type": "string",
      "enum": [
        "agent-workflows",
        "docs",
        "evaluation",
        "system-recovery",
        "validation-patterns",
        "history"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "canonical",
        "promoted",
        "deprecated"
      ]
    },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project",
        "path",
        "note"
      ],
      "properties": {
        "project": {
          "type": "string",
          "minLength": 2
        },
        "path": {
          "type": "string",
          "minLength": 2
        },
        "note": {
          "type": "string",
          "minLength": 10
        }
      }
    },
    "owners": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "summary": {
      "type": "string",
      "minLength": 10
    },
    "maturity_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "rigor_level": {
      "type": "string",
      "enum": [
        "light",
        "bounded",
        "strict"
      ]
    },
    "reversibility": {
      "type": "string",
      "enum": [
        "easy",
        "moderate",
        "hard"
      ]
    },
    "review_required": {
      "type": "boolean"
    },
    "validation_strength": {
      "type": "string",
      "enum": [
        "baseline",
        "source_backed",
        "cross_context"
      ]
    },
    "public_safety_reviewed_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "export_ready": {
      "type": "boolean"
    },
    "relations": {
      "type": "array",
      "items": {
        "$ref": "relation.schema.json"
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "evidence-note.schema.json"
      }
    }
  }
}
